# Contact form (server-side, used by /api/contact)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives messages from the contact form
CONTACT_TO_EMAIL=you@example.com

# Verified sender address in Resend (must be on a domain you've verified)
CONTACT_FROM_EMAIL=contact@yourdomain.com
